# --- Out-of-source build directories ---
/build/
/_build*/
/lib/
/agent-skills

# --- Optional local mesh-backend dependency checkouts/install roots ---
# Keep Eigen tracked, but do not commit heavyweight optional backend sources or binaries.
/third_party/assimp/
/third_party/boost/
/third_party/coal/
/third_party/fcl/
/third_party/install/
/third_party/libccd/

# --- qmake / make generated files (in-source) ---
Makefile
Makefile.Debug
Makefile.Release
.qmake.stash
.qmake.cache
.qmake.super

# --- Per-target build subdirectories ---
.obj/
.moc/
.rcc/
.ui/
debug/
release/

# --- Compiled objects / binaries ---
*.o
*.obj
*.lib
*.a
*.dll
*.exe
*.pdb
*.ilk
*.exp

# --- Qt moc/rcc/uic outputs ---
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h
*.moc

# --- Qt Creator user/session files ---
*.pro.user
*.pro.user.*
.qtcreator/

# --- Local agent/editor config ---
/.claude/

# --- Generated mesh-simplification artifacts ---
# tools/mesh_simplification regenerates these from the original mesh profile.
/collision_profiles/simplified/
/collision_profiles/*_simplified*.json
